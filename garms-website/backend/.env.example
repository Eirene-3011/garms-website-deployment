# ─── Server ───────────────────────────────────────────────
PORT=5000

# ─── TiDB Cloud (MySQL-compatible) ────────────────────────
# Get these from your TiDB Cloud cluster → Connect → Node.js
DB_HOST=gateway01.us-east-1.prod.aws.tidbcloud.com
DB_PORT=4000
DB_USER=your_tidb_user
DB_PASSWORD=your_tidb_password
DB_NAME=garms_db
DB_SSL=true

# ─── Cloudinary ───────────────────────────────────────────
# Get these from Cloudinary Dashboard → Settings → API Keys
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── JWT / Admin Auth ─────────────────────────────────────
# Change both of these before deploying to production!
JWT_SECRET=change_this_to_a_long_random_string_in_production
ADMIN_MAGIC_CODE=107960

# ─── Frontend URL (CORS) ──────────────────────────────────
# Set this to your Netlify URL after deploying the frontend.
# Multiple origins: comma-separated, e.g.  https://garms.netlify.app,https://garms107960.edu.ph
FRONTEND_URL=http://localhost:5173
